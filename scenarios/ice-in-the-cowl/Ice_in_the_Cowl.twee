.cs-item:last-child { border-right: none; }
.cs-label { color: #7a8aa8; font-size: 0.8em; letter-spacing: 0.05em; }
.cs-val { color: #e8f0ff; font-weight: bold; margin-left: 0.4em; }
.cs-ice-0 .cs-val { color: #9ae0a5; }
.cs-ice-1 .cs-val { color: #e0d89a; }
.cs-ice-2 .cs-val { color: #e8b874; }
.cs-ice-3 .cs-val { color: #e88c5a; }
.cs-ice-4 .cs-val { color: #e86060; }

/* Main Menu button (injected) */
.main-menu-wrap { margin-top: 2em; text-align: center; }
