  margin-bottom: 1.5em;
  font-style: italic;
}

.preflight-btn {
  display: inline-block;
  background: #16213e;
  border: 1px solid #0f3460;
  border-radius: 6px;
  padding: 10px 20px;
  margin: 6px 4px;
  min-width: 230px;
  text-align: center;
  color: #e0e0e0;
  text-decoration: none;
  transition: background 0.2s;
}
.preflight-btn:hover { background: #0f3460; color: #ffffff; }

.metar-block, .flight-plan, .aircraft-card {
  background-color: #0b1828;
  padding: 1em;
  border-radius: 6px;
  font-family: 'Courier New', monospace;
  margin: 0.5em 0;
  white-space: pre-wrap;
  font-size: 0.95em;
}

.airport-table { width: 100%; border-collapse: collapse; margin: 0.5em 0; font-size: 0.9em; }
.airport-table th, .airport-table td { padding: 6px 10px; border-bottom: 1px solid #2a3a56; text-align: left; }
.airport-table th { color: #9ab0c8; }

.debrief {
  border-top: 2px solid #4a5a78;
  padding-top: 1em;
  margin-top: 2em;
  background: rgba(20,28,44,0.5);
  border-radius: 6px;
  padding: 1.2em 1.4em;
}

.chart-disclaimer {
  font-size: 0.8em;
  color: #8090a8;
  border-left: 3px solid #3a4a6c;
  padding: 6px 12px;
  margin: 1em 0;
}

.sectional-container { margin: 1em 0; }
.sectional-container img {
  max-width: 100%;
  border: 1px solid #2a3a56;
  border-radius: 4px;
}
.sectional-label { font-size: 0.85em; color: #8090a8; margin-top: 0.3em; }

.audio-toggle {
  position: fixed;
  top: 10px;
  right: 10px;
  padding: 6px 12px;
  background: rgba(36, 50, 79, 0.85);
  color: #c8d8f0;
  border: 1px solid #3a4a6c;
  border-radius: 6px;
  font-size: 0.85em;
  cursor: pointer;
  z-index: 100;
}
.audio-toggle.muted { background: rgba(60, 40, 40, 0.85); color: #aa8888; }

.contact-atc-btn {
  position: fixed;
  bottom: 14px;
  right: 14px;
  padding: 10px 16px;
  background: rgba(36, 50, 79, 0.92);
  color: #e8f0ff;
  border: 1px solid #4a6a8c;
  border-radius: 8px;
  font-size: 0.95em;
  cursor: pointer;
  z-index: 100;
  box-shadow: 0 3px 10px rgba(0,0,0,0.4);
}
.contact-atc-btn:hover { background: rgba(58, 90, 140, 0.95); }

/* Cockpit instrument strip — shown on flight passages */
.cockpit-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 0.6em;
  justify-content: center;
  background: #07101c;
  border: 1px solid #2a3a56;
  border-radius: 6px;
  padding: 0.6em;
  margin: 0 0 1.2em 0;
  font-family: 'Courier New', monospace;
