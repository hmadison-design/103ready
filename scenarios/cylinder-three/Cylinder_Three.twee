:: StoryScript [script]
/* Audio helper: crossfade between engine states */
window.crossfadeEngine = function(from, to, duration) {
	if (!State.variables.audioEnabled) return;
	duration = duration || 2000;
	var steps = 20;
	var interval = duration / steps;
	var fromTrack = SimpleAudio.tracks.get(from);
	var toTrack = SimpleAudio.tracks.get(to);
	if (!fromTrack || !toTrack) return;

	var fromVol = fromTrack.volume();
	toTrack.volume(0);
	toTrack.loop(true);
	toTrack.play();

	var step = 0;
	var fade = setInterval(function() {
		step++;
		var progress = step / steps;
		fromTrack.volume(fromVol * (1 - progress));
		toTrack.volume(fromVol * progress);
		if (step >= steps) {
			clearInterval(fade);
			fromTrack.stop();
			toTrack.volume(fromVol);
		}
	}, interval);
};

/* Audio helper: play a one-shot sound */
window.playOneShot = function(trackId, volume) {
	if (!State.variables.audioEnabled) return;
	var track = SimpleAudio.tracks.get(trackId);
	if (!track) return;
	track.volume(volume || 1.0);
	track.play();
};

/* Audio toggle button — added to every passage via :passagerender */
$(document).on(":passagerender", function(ev) {
	/* Remove any existing toggle so we don't duplicate */
	$("#audio-toggle-btn").remove();
	var btn = $('<button id="audio-toggle-btn" class="audio-toggle"></button>');
	var updateLabel = function() {
		if (State.variables.audioEnabled) {
			btn.text("🔊 Audio On").removeClass("muted");
		} else {
			btn.text("🔇 Audio Off").addClass("muted");
		}
	};
	btn.on("click", function() {
		State.variables.audioEnabled = !State.variables.audioEnabled;
		if (!State.variables.audioEnabled) {
			SimpleAudio.muteOnHidden(false);
			/* Stop all audio */
			SimpleAudio.tracks.forEach(function(track) { track.stop(); });
		}
		updateLabel();
	});
	updateLabel();
	$("body").append(btn);
});

/* Sectional chart zoom — opens high-res chart in a pan/zoom viewer */
window.openZoomChart = function() {
	var zoomSrc = document.getElementById("sectional-zoom-data").textContent.trim();
	/* Popup is about:blank — prepend origin so root-relative paths resolve. */
	if (zoomSrc && !/^(data:|https?:)/.test(zoomSrc)) {
		if (zoomSrc.charAt(0) !== '/') zoomSrc = '/' + zoomSrc;
		zoomSrc = window.location.origin + zoomSrc;
	}
	var w = window.open("", "_blank");
	if (!w) { alert("Pop-up blocked — please allow pop-ups for this site."); return; }
	var html = [
		"<!DOCTYPE html><html><head><title>VFR Sectional — KSWO to KCSM</title>",
		"<style>",
		"*{margin:0;padding:0;box-sizing:border-box}",
		"body{background:#111;overflow:hidden;width:100vw;height:100vh;cursor:grab}",
		"body.dragging{cursor:grabbing}",
		"#viewport{width:100%;height:100%;overflow:hidden;position:relative}",
		"#chart{position:absolute;transform-origin:0 0;transition:none}",
		".controls{position:fixed;bottom:20px;right:20px;display:flex;gap:8px;z-index:10}",
		".controls button{width:40px;height:40px;border:none;border-radius:8px;",
		"  background:#1a5fb4;color:#fff;font-size:20px;cursor:pointer;",
		"  font-weight:bold;transition:background 0.2s;box-shadow:0 2px 6px rgba(0,0,0,0.4)}",
		".controls button:hover{background:#2878d8}",
		".zoom-level{position:fixed;bottom:24px;right:160px;color:rgba(255,255,255,0.5);",
		"  font:13px/1 system-ui,sans-serif;z-index:10}",
		"</style></head><body>",
		"<div id=\"viewport\"><img id=\"chart\" src=\"" + zoomSrc + "\"></div>",
		"<div class=\"zoom-level\" id=\"zlabel\">100%</div>",
		"<div class=\"controls\">",
		"  <button id=\"zout\" title=\"Zoom out\">−</button>",
		"  <button id=\"zin\" title=\"Zoom in\">+</button>",
		"  <button id=\"zfit\" title=\"Fit to window\">⊡</button>",
		"</div>",
		"<script>",
		"var img=document.getElementById('chart'),",
		"    vp=document.getElementById('viewport'),",
		"    zlabel=document.getElementById('zlabel'),",
		"    scale=1,minScale=0.1,maxScale=8,",
		"    tx=0,ty=0,dragging=false,startX,startY,startTx,startTy;",
		"",
		"function apply(){img.style.transform='translate('+tx+'px,'+ty+'px) scale('+scale+')';",
		"  zlabel.textContent=Math.round(scale*100)+'%'}",
		"",
		"/* Fit image to viewport on load */",
		"img.onload=function(){",
		"  var s=Math.min(vp.clientWidth/img.naturalWidth,vp.clientHeight/img.naturalHeight);",
		"  scale=s;minScale=s*0.5;",
		"  tx=(vp.clientWidth-img.naturalWidth*scale)/2;",
		"  ty=(vp.clientHeight-img.naturalHeight*scale)/2;",
		"  apply()};",
		"",
		"/* Mouse-wheel zoom toward cursor */",
		"vp.addEventListener('wheel',function(e){",
		"  e.preventDefault();",
		"  var rect=vp.getBoundingClientRect(),",
		"      mx=e.clientX-rect.left,my=e.clientY-rect.top,",
		"      prev=scale,",
		"      factor=e.deltaY<0?1.15:1/1.15;",
		"  scale=Math.min(maxScale,Math.max(minScale,scale*factor));",
		"  tx=mx-(mx-tx)*(scale/prev);",
		"  ty=my-(my-ty)*(scale/prev);",
		"  apply()},{passive:false});",
		"",
		"/* Click-drag panning */",
		"vp.addEventListener('mousedown',function(e){",
		"  dragging=true;startX=e.clientX;startY=e.clientY;startTx=tx;startTy=ty;",
		"  document.body.classList.add('dragging');e.preventDefault()});",
		"window.addEventListener('mousemove',function(e){",
		"  if(!dragging)return;",
		"  tx=startTx+(e.clientX-startX);ty=startTy+(e.clientY-startY);apply()});",
		"window.addEventListener('mouseup',function(){",
		"  dragging=false;document.body.classList.remove('dragging')});",
		"",
		"/* Touch pan/pinch */",
		"var lastDist=0,lastMid={x:0,y:0};",
		"vp.addEventListener('touchstart',function(e){",
		"  if(e.touches.length===1){dragging=true;startX=e.touches[0].clientX;startY=e.touches[0].clientY;startTx=tx;startTy=ty}",
		"  if(e.touches.length===2){dragging=false;var dx=e.touches[1].clientX-e.touches[0].clientX,dy=e.touches[1].clientY-e.touches[0].clientY;",
		"    lastDist=Math.hypot(dx,dy);lastMid={x:(e.touches[0].clientX+e.touches[1].clientX)/2,y:(e.touches[0].clientY+e.touches[1].clientY)/2}}",
		"  e.preventDefault()},{passive:false});",
		"vp.addEventListener('touchmove',function(e){",
		"  if(e.touches.length===1&&dragging){tx=startTx+(e.touches[0].clientX-startX);ty=startTy+(e.touches[0].clientY-startY);apply()}",
		"  if(e.touches.length===2){var dx=e.touches[1].clientX-e.touches[0].clientX,dy=e.touches[1].clientY-e.touches[0].clientY,",
		"    dist=Math.hypot(dx,dy),mid={x:(e.touches[0].clientX+e.touches[1].clientX)/2,y:(e.touches[0].clientY+e.touches[1].clientY)/2},",
		"    rect=vp.getBoundingClientRect(),mx=mid.x-rect.left,my=mid.y-rect.top,",
		"    prev=scale;scale=Math.min(maxScale,Math.max(minScale,scale*(dist/lastDist)));",
		"    tx=mx-(mx-tx)*(scale/prev);ty=my-(my-ty)*(scale/prev);lastDist=dist;apply()}",
		"  e.preventDefault()},{passive:false});",
		"",
		"/* Button controls */",
		"function zoomBtn(factor){",
		"  var rect=vp.getBoundingClientRect(),cx=rect.width/2,cy=rect.height/2,prev=scale;",
		"  scale=Math.min(maxScale,Math.max(minScale,scale*factor));",
		"  tx=cx-(cx-tx)*(scale/prev);ty=cy-(cy-ty)*(scale/prev);apply()}",
		"document.getElementById('zin').onclick=function(){zoomBtn(1.3)};",
		"document.getElementById('zout').onclick=function(){zoomBtn(1/1.3)};",
		"document.getElementById('zfit').onclick=function(){img.onload()};",
		"</scr"+"ipt></body></html>"
	].join("");
	w.document.write(html);
	w.document.close();
};

